@model SendMail9.ViewModels.OrderInputVM
@{
    ViewData["Title"] = "Demo Order - Met Producten";
}

<div class="row">
    <div class="col-md-6 offset-md-3">
        <h2 class="mb-4">Demo Order - Email met Producten</h2>
        
        <div class="alert alert-info" role="alert">
            <strong>Info:</strong> Deze demo verstuurt een orderbevestiging met een lijst van producten.
        </div>

        @if (ViewBag.Message != null)
        {
            <div class="alert alert-success" role="alert">
                <strong>Success!</strong> @ViewBag.Message
            </div>
        }

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger" role="alert">
                <strong>Error!</strong> @ViewBag.Error
            </div>
        }

        <form asp-action="DemoOrderAttachment" method="post">
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Naam</label>
                <input asp-for="Name" class="form-control" placeholder="Vul uw naam in" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" type="email" placeholder="voorbeeld@email.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="card mb-3">
                <div class="card-header">
                    <strong>Demo Producten die verzonden worden:</strong>
                </div>
                <div class="card-body">
                    <ul>
                        <li>6x Duvel - €2.50</li>
                        <li>12x Jupiler - €1.20</li>
                        <li>4x La Chouffe - €3.00</li>
                        <li>6x Westmalle Tripel - €2.80</li>
                    </ul>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Verstuur Order met Producten</button>
            <a asp-action="DemoOrder" class="btn btn-secondary">Terug</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
