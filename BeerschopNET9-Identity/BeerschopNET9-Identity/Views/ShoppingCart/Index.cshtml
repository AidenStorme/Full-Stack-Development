@using BeerschopNET9_Identity.ViewModels
@model BeerschopNET9_Identity.ViewModels.ShoppingCartVM

@{
    ViewData["Title"] = "Shopping Cart";
    var carts = Model?.Carts ?? new List<CartVM>();
    var grandTotal = carts.Sum(x => x.Price * x.Count);
}

<h2>Shopping Cart</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

@if (!carts.Any())
{
    <div class="alert alert-info">
        Je shopping cart is leeg.
    </div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Product</th>
                <th class="text-end">Prijs</th>
                <th class="text-center" style="width: 220px;">Aantal</th>
                <th class="text-end">Totaal</th>
                <th class="text-end" style="width: 160px;">Acties</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in carts)
            {
                var lineTotal = item.Price * item.Count;

                <tr>
                    <td>
                        <div class="fw-semibold">@item.Name</div>

                    </td>

                    <td class="text-end">@item.Price.ToString("0.00")</td>

                    <td class="text-center">
                        <form asp-action="UpdateCount" class="d-inline-flex gap-2 justify-content-around">
                            <input type="hidden" name="beerNumber" value="@item.BeerNumber" />
                            <input type="number"
                                  name="count"
                                  value="@item.Count"
                                  min=" ="1"
                                  step="1"
                                  class="form-control"
                                  style="width: 90px" />
                            <button type="submit" class="btn btn-sm btn-info">
                                Update
                            </button>
                        </form>
                        @*item.Count*@
                    </td>

                    <td class="text-end">@lineTotal.ToString("0.00")</td>

                    <td class="text-end">
                        <form asp-action="Remove"

                            class="d-inline">

                        <input type="hidden" name="beerNumber" value="@item.BeerNumber" />
                        <button type="submit"class="btn btn-sm btn-danger">
                            Verwijder
                        </button>
                        </form>
                        
                    </td>
                </tr>
            }
        </tbody>

        <tfoot>
            <tr>
                <td colspan="3" class="text-end fw-bold"> Totaal:</td>
                <td class="text-end fw-bold">@grandTotal.ToString("0.00")</td>
                <td></td>
            </tr>
        </tfoot>
    </table>

    <div class="d-flex justify-content-between mt-4">
        <a asp-controller="Beer"
           asp-action="Index"
           class="btn btn-outline-secondary">
            ← Verder winkelen
        </a>

        <a asp-action="Payment"
           class="btn btn-success">
            Naar checkout →
        </a>
    </div>
}